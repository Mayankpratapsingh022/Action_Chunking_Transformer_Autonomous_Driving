{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Urban VLA frame telemetry",
  "type": "object",
  "required": ["frameIndex", "timestamp", "observation", "action", "routeProgress"],
  "properties": {
    "frameIndex": { "type": "integer", "minimum": 0 },
    "timestamp": { "type": "number", "minimum": 0 },
    "observation": {
      "type": "object",
      "required": ["state"],
      "properties": {
        "state": { "type": "array", "minItems": 4, "maxItems": 4, "items": { "type": "number" } }
      }
    },
    "action": { "type": "array", "minItems": 3, "maxItems": 3, "items": { "type": "number" } },
    "routeProgress": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
