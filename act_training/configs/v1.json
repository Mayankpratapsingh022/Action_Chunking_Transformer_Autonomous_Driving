{
  "dataset_repo": "Mayank022/urban-vla-expert-v1",
  "dataset_revision": "main",
  "model_repo": "Mayank022/urban-vla-language-act",
  "run_name": "act-driving-v1",
  "artifact_root": "/artifacts/runs",
