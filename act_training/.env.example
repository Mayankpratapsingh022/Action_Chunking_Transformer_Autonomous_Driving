# Required: Hugging Face token with write access to the target model repository.
HF_TOKEN=

# Optional: leave blank when `modal setup` has already authenticated this machine.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Required for RunPod API launch/status/stop/terminate commands.
RUNPOD_API_KEY=

# Create this once with `python runpod_launcher.py create-volume ...`.
RUNPOD_NETWORK_VOLUME_ID=

# Create this secret in the RunPod console and store the same value as HF_TOKEN.
RUNPOD_HF_SECRET_NAME=huggingface_token

# RunPod launch defaults. Separate fallback GPU IDs with `|`.
RUNPOD_GPU_TYPE_IDS=NVIDIA H100 80GB HBM3
RUNPOD_IMAGE=pytorch/pytorch:2.8.0-cuda12.8-cudnn9-runtime
RUNPOD_GIT_REPO=https://github.com/Mayankpratapsingh022/Action_Chunking_Transformer_Autonomous_Driving.git
RUNPOD_GIT_REF=main
